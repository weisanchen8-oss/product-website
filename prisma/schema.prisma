// 文件作用：
// 定义第一版 B2B 产品展示与询单平台的 Prisma 数据模型。
// 当前阶段先建立产品、分类、询单、站点内容和产品图片等核心表结构。

// 文件作用：
// 定义第一版 B2B 产品展示与询单平台的数据模型。
// Prisma 7 中数据库连接 URL 不再写在 schema.prisma，而写在 prisma.config.ts。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String
  slug        String     @unique
  description String?
  parentId    Int?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  parent      Category?  @relation("CategoryToChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToChildren")
  products    Product[]
}

model Product {
  id             Int            @id @default(autoincrement())
  name           String
  slug           String         @unique
  shortDesc      String
  fullDesc       String?
  keywords       String?
  priceText      String
  specsJson      String?
  isActive       Boolean        @default(true)

  isFeatured     Boolean        @default(false)
  featuredSort   Int            @default(0)

  isManualHot    Boolean        @default(false)
  manualHotSort  Int            @default(0)
  salesCount     Int            @default(0)

  categoryId     Int
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  category       Category       @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  inquiryItems   InquiryItem[]
}

model ProductImage {
  id               Int       @id @default(autoincrement())
  productId        Int
  originalUrl      String
  processedUrl     String?
  isProcessed      Boolean   @default(false)
  processingStatus String    @default("pending")
  processingError  String?
  logoApplied      Boolean   @default(false)
  sortOrder        Int       @default(0)
  isCover          Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  product          Product   @relation(fields: [productId], references: [id])
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  companyName  String
  phone        String
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  inquiries    Inquiry[]
}

model Employee {
  id         Int          @id @default(autoincrement())
  name       String
  email      String       @unique
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  logs       InquiryLog[]
}

model Inquiry {
  id                 Int          @id @default(autoincrement())
  inquiryNo          String       @unique
  userId             Int
  contactName        String
  companyName        String
  phone              String
  email              String
  region             String?
  remark             String?
  estimatedTotalText String
  status             String       @default("pending")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  user               User         @relation(fields: [userId], references: [id])
  items              InquiryItem[]
  logs               InquiryLog[]
}

model InquiryItem {
  id                  Int       @id @default(autoincrement())
  inquiryId           Int
  productId           Int
  productNameSnapshot String
  priceSnapshot       String
  quantity            Int
  subtotalSnapshot    String?
  createdAt           DateTime  @default(now())

  inquiry             Inquiry   @relation(fields: [inquiryId], references: [id])
  product             Product   @relation(fields: [productId], references: [id])
}

model InquiryLog {
  id           Int       @id @default(autoincrement())
  inquiryId    Int
  employeeId   Int?
  status       String
  note         String?
  operatorName String?
  createdAt    DateTime  @default(now())

  inquiry      Inquiry   @relation(fields: [inquiryId], references: [id])
  employee     Employee? @relation(fields: [employeeId], references: [id])
}

model SiteContent {
  id         Int       @id @default(autoincrement())
  contentKey String    @unique
  title      String?
  content    String?
  imageUrl   String?
  extraJson  String?
  updatedAt  DateTime  @updatedAt
}