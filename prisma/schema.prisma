// 文件作用：
// 定义第一版 B2B 产品展示与询单平台的 Prisma 数据模型。
// 当前阶段先建立产品、分类、询单、站点内容和产品图片等核心表结构。

// 文件作用：
// 定义第一版 B2B 产品展示与询单平台的数据模型。
// Prisma 7 中数据库连接 URL 不再写在 schema.prisma，而写在 prisma.config.ts。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  nameEn        String?
  descriptionEn String?
  slug        String   @unique
  description String?
  imageUrl    String?
  parentId    Int?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryToChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToChildren")
  products Product[]
}

model Product {
  id        Int     @id @default(autoincrement())
  name      String
  nameEn      String?
  shortDescEn String?
  fullDescEn  String?
  slug      String  @unique
  shortDesc String
  fullDesc  String?
  keywords  String?
  priceText String
  specsJson String?
  specsJsonEn String?
  isActive  Boolean @default(true)

  isFeatured   Boolean @default(false)
  featuredSort Int     @default(0)

  isManualHot   Boolean @default(false)
  manualHotSort Int     @default(0)
  salesCount    Int     @default(0)

  categoryId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category     Category       @relation(fields: [categoryId], references: [id])
  images       ProductImage[]
  inquiryItems InquiryItem[]
  promotionProducts PromotionProduct[]
}

model Promotion {
  id            Int      @id @default(autoincrement())
  title         String
  titleEn       String?
  description   String?
  descriptionEn String?
  discountType  String   @default("percent")
  discountValue Float
  startAt       DateTime
  endAt         DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products PromotionProduct[]
}

model PromotionProduct {
  id          Int      @id @default(autoincrement())
  promotionId Int
  productId   Int
  createdAt   DateTime @default(now())

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promotionId, productId])
}

model ProductImage {
  id                  Int       @id @default(autoincrement())
  productId           Int
  watermarkedUrl      String?
  watermarkType       String?
  watermarkText       String?
  watermarkAppliedAt  DateTime?
  
  // 原图地址：用户上传后的原始产品图片
  originalUrl         String

  // AI处理后的图片地址：例如白底图、去背景图、水印图
  processedUrl        String?

  // 是否已经成功生成处理图
  isProcessed         Boolean   @default(false)

  // AI处理状态：
  // idle = 未处理
  // processing = 处理中
  // success = 处理成功
  // failed = 处理失败
  processingStatus    String    @default("idle")

  // AI处理失败时记录错误原因
  processingError     String?

  // 实际使用的AI服务商，例如 removebg / replicate / photoroom
  aiProvider          String?

  // AI处理完成时间
  processedAt         DateTime?

  // 是否优先使用处理图作为封面展示
  useProcessedAsCover Boolean   @default(false)

  // 是否已添加Logo或水印
  logoApplied         Boolean   @default(false)

  sortOrder           Int       @default(0)
  isCover             Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id])
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  companyName  String
  phone        String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isImportant  Boolean  @default(false)

  inquiries Inquiry[]
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs InquiryLog[]
}

model Inquiry {
  id                 Int      @id @default(autoincrement())
  inquiryNo          String   @unique
  userId             Int
  contactName        String
  companyName        String
  phone              String
  email              String
  region             String?
  remark             String?
  adminNote          String?
  estimatedTotalText String
  status             String   @default("pending")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id])
  items InquiryItem[]
  logs  InquiryLog[]
}

model InquiryItem {
  id                  Int      @id @default(autoincrement())
  inquiryId           Int
  productId           Int?
  productNameSnapshot String
  priceSnapshot       String
  quantity            Int
  subtotalSnapshot    String?
  createdAt           DateTime @default(now())

  inquiry Inquiry @relation(fields: [inquiryId], references: [id])
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model InquiryLog {
  id         Int  @id @default(autoincrement())
  inquiryId  Int
  employeeId Int?

  type       String  @default("status")
  fromStatus String?
  toStatus   String?

  status       String?
  note         String?
  operatorName String?
  createdAt    DateTime @default(now())

  inquiry  Inquiry   @relation(fields: [inquiryId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])
}

model SiteContent {
  id          Int      @id @default(autoincrement())
  contentKey  String   @unique
  title       String?
  titleEn     String?
  content     String?
  contentEn   String?
  imageUrl    String?
  extraJson   String?
  extraJsonEn String?
  updatedAt   DateTime @updatedAt
}

model AdminLog {
  id                Int       @id @default(autoincrement())
  module            String
  action            String
  targetId          Int?
  targetName        String?
  operatorName      String?
  note              String?
  beforeData        String?
  afterData         String?
  rolledBackAt      DateTime?
  rollbackFromLogId Int?
  createdAt         DateTime  @default(now())
}

/// 文件作用：
/// 行业风险监控指标表。
/// 用于手动维护汇率、国际运费、关税政策、市场风险等指标，
/// 并通过预警阈值和高风险阈值判断是否需要提醒管理员核对售价、运费或报价策略。
model MarketMonitorIndicator {
  id String @id @default(cuid())

  /// 指标名称，例如：美元兑人民币汇率、海运费指数、美国关税政策风险
  name String

  /// 指标类型：
  /// exchange_rate 汇率
  /// shipping 国际运费
  /// tariff_policy 关税政策
  /// market_risk 市场风险
  /// other 其他
  type String

  /// 当前值
  currentValue Float

  /// 预警阈值
  warningThreshold Float

  /// 高风险阈值
  dangerThreshold Float

  /// 阈值比较方向：
  /// gte 表示当前值 >= 阈值时触发风险
  /// lte 表示当前值 <= 阈值时触发风险
  compareMode String @default("gte")

  /// 单位，例如：%、USD、CNY、指数点
  unit String?

  /// 风险等级：
  /// normal 正常
  /// warning 预警
  /// danger 高风险
  riskLevel String @default("normal")

  /// 风险说明
  description String?

  /// 是否启用
  isActive Boolean @default(true)

  /// 创建时间
  createdAt DateTime @default(now())

  /// 更新时间
  updatedAt DateTime @updatedAt
}